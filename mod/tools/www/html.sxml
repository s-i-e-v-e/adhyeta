(html @lang "en"

(head
    (meta @charset "UTF-8")
    (meta @name "viewport" @content "width=device-width, initial-scale=1")
    (title अध्येता - A Sanskrit Reader{{title}})
    (link @rel "stylesheet" @href "/a/main.css")
)

(body

(header
(p ॐ श्री गणपतये नमः)
(h1 अध्येता - A Sanskrit Reader)
)

(main {{nav}}{{main}})

(footer
(p (a @href "/copyright.sxml" Copyright))
)

)
)